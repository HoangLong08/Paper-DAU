        <mxCell id="b4" value="④  LUẬN ĐỀ DUY NHẤT (bán cái này — KHÔNG bán 4 mệnh đề rời)" style="swimlane;html=1;startSize=40;fillColor=#d5e8d4;strokeColor=#82b366;swimlaneFillColor=#ffffff;fontStyle=1;fontSize=14;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="1560" height="160" as="geometry" />
        </mxCell>
        <mxCell id="n41" value="&lt;b&gt;Trong miền có ground truth lâm sàng, khoảng cách tối ưu&#xa;mà cả dòng văn liệu đang tranh nhau&#xa;KHÔNG chiếu xuống mask lâm sàng.&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;strokeWidth=2;" vertex="1" parent="b4">
          <mxGeometry x="180" y="50" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n42" value="&lt;b&gt;BẤT TỬ trước kết quả thực nghiệm&lt;/b&gt; — đúng ở CẢ HAI nhánh:&#xa;• Mọi thuật toán ĐẠT tối ưu ⇒ optimizer là ĐỒ TRANG TRÍ&#xa;• KHÔNG đạt ⇒ cả một thập kỷ engineering đang đóng&#xa;   một gap chứng minh được là VÔ NGHĨA với lâm sàng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="b4">
          <mxGeometry x="960" y="50" width="480" height="90" as="geometry" />
        </mxCell>
        <mxCell id="e41" value="vì sao an toàn" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82b366;labelBackgroundColor=#ffffff;fontSize=11;" edge="1" parent="b4" source="n41" target="n42">
