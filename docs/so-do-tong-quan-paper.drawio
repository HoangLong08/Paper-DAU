        <mxCell id="e31" value="KHÔNG" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#b85450;dashed=1;labelBackgroundColor=#ffffff;fontSize=11;" edge="1" parent="b3" source="d31" target="n32">
