        <mxCell id="title" value="QIGOA REALITY-CHECK — SƠ ĐỒ TỔNG QUAN TOÀN BỘ PAPER&#xa;từ hướng nghiên cứu gốc đến đầu ra" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1560" height="60" as="geometry" />
        </mxCell>

        <mxCell id="b1" value="①  HƯỚNG NGHIÊN CỨU GỐC (đề thầy giao)" style="swimlane;html=1;startSize=40;fillColor=#dae8fc;strokeColor=#6c8ebf;swimlaneFillColor=#ffffff;fontStyle=1;fontSize=14;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="1560" height="170" as="geometry" />
        </mxCell>
        <mxCell id="n11" value="&lt;b&gt;Đề TS. Đỗ Phúc Hảo giao&lt;/b&gt;&#xa;QIGOA = GOA (đàn châu chấu) + Q-bit&#xa;+ rotation gate · hàm Kapur entropy&#xa;Dữ liệu: BraTS 2020 (MRI u não)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="b1">
          <mxGeometry x="30" y="60" width="380" height="85" as="geometry" />
        </mxCell>
        <mxCell id="n12" value="&lt;b&gt;Câu hỏi GỐC&lt;/b&gt;&#xa;&#xa;« QIGOA có THẮNG các&#xa;metaheuristic khác không? »" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="b1">
          <mxGeometry x="490" y="60" width="320" height="85" as="geometry" />
        </mxCell>
        <mxCell id="n13" value="&lt;b&gt;Chẩn đoán đề gốc&lt;/b&gt;&#xa;sai loại metric · sai venue · zero novelty&#xa;hai lớp metaphor (lượng tử + châu chấu)&#xa;⇒ KHÔNG extend lên journal được" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="b1">
          <mxGeometry x="890" y="60" width="420" height="85" as="geometry" />
        </mxCell>
        <mxCell id="e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;" edge="1" parent="b1" source="n11" target="n12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#b85450;" edge="1" parent="b1" source="n12" target="n13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="b2" value="②  PHÁT HIỆN — 3 sự thật từ dữ liệu + collision-check văn liệu" style="swimlane;html=1;startSize=40;fillColor=#f8cecc;strokeColor=#b85450;swimlaneFillColor=#ffffff;fontStyle=1;fontSize=14;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="1560" height="200" as="geometry" />
        </mxCell>
        <mxCell id="n21" value="&lt;b&gt;① SUY BIẾN (degeneracy)&lt;/b&gt;&#xa;Tối ưu k ngưỡng, nhưng mask u cuối&#xa;chỉ phụ thuộc 1–2 ngưỡng&#xa;⇒ đang tối ưu một biến&#xa;KHÔNG ảnh hưởng đầu ra" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="b2">
          <mxGeometry x="30" y="60" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n22" value="&lt;b&gt;② ĐÃ CÓ LỜI GIẢI CHÍNH XÁC&lt;/b&gt;&#xa;DP exact Kapur, O(k·L²), &lt; 160 ms&#xa;Menotti et al., CIARP 2015&#xa;⇒ dò tìm bằng metaheuristic&#xa;là THỪA (11 năm trước đã có)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="b2">
          <mxGeometry x="410" y="60" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n23" value="&lt;b&gt;③ GOODHART&lt;/b&gt;&#xa;k tăng → Kapur / PSNR / SSIM TĂNG&#xa;nhưng Dice (khớp u thật) GIẢM&#xa;⇒ cả ngành đang&#xa;ĐO SAI THỨ CẦN ĐO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="b2">
          <mxGeometry x="790" y="60" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n24" value="&lt;b&gt;NEAR-RIVAL đã in trước&lt;/b&gt;&#xa;Hammouche 2010 · Lipton 2014&#xa;François &amp;amp; Tinarrage 2026 (trần 0,83)&#xa;Hegazy &amp;amp; Gabr 2026 (2 bài/tháng)&#xa;⇒ phải PHÂN BIỆT, không claim mới" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="b2">
          <mxGeometry x="1170" y="60" width="340" height="110" as="geometry" />
        </mxCell>

        <mxCell id="b3" value="③  NGÃ RẼ ĐẠO ĐỨC — điểm quyết định của cả dự án" style="swimlane;html=1;startSize=40;fillColor=#fff2cc;strokeColor=#d6b656;swimlaneFillColor=#ffffff;fontStyle=1;fontSize=14;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="1560" height="170" as="geometry" />
        </mxCell>
        <mxCell id="n32" value="&lt;b&gt;❌ Bịa số cho « thắng »&lt;/b&gt;&#xa;= vi phạm IRON RULE 1&#xa;= huỷ sự nghiệp nghiên cứu&#xa;(ĐƯỜNG BỊ CHẶN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;dashed=1;" vertex="1" parent="b3">
          <mxGeometry x="100" y="60" width="340" height="85" as="geometry" />
        </mxCell>
        <mxCell id="d31" value="&lt;b&gt;Dữ liệu nói ngược&#xa;kỳ vọng ⇒ làm gì?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="b3">
          <mxGeometry x="580" y="55" width="280" height="95" as="geometry" />
        </mxCell>
        <mxCell id="n33" value="&lt;b&gt;✅ PIVOT — giữ QIGOA làm nhân vật&#xa;trung tâm nhưng ĐỔI CÂU HỎI&lt;/b&gt;&#xa;« QIGOA có thực sự giúp không,&#xa;và ta đang đo đúng thứ chưa? »" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="b3">
          <mxGeometry x="1000" y="60" width="420" height="85" as="geometry" />
