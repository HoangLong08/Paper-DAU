        <mxCell id="n73" value="&lt;b&gt;3 ĐÓNG GÓP DƯƠNG&lt;/b&gt;&#xa;① Phân rã trần Dice (chưa ai làm)&#xa;② Công cụ chẩn đoán O(L·log L)&#xa;③ Checklist giao thức đánh giá&#xa;    + Bảng I trắc lượng (2 coder, κ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="b7">
